{
  "name": "@ab-ads/backend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "module": "./dist/backend/src/server.js",
  "scripts": {
    "dev": "tsx watch ./src/server.ts",
    "build": "tsc && tsc-alias",
    "start": "node ./dist/backend/src/server.js",
    "type-check": "tsc --noEmit",
    "format": "prettier --write ./src ./seed",
    "lint": "eslint ./src ./seed",
    "lint:fix": "eslint ./src ./seed --fix",
    "seed": "tsx ./seed/index.ts",
    "prisma:generate": "prisma generate"
  },
  "dependencies": {
    "@google-cloud/documentai": "^9.3.0",
    "@google-cloud/pubsub": "^5.1.0",
    "@google-cloud/storage": "^7.16.0",
    "@google-cloud/vision": "^5.3.2",
    "@hono/node-server": "^1.14.2",
    "@hono/zod-validator": "^0.7.0",
    "@prisma/client": "^6.10.0",
    "@sendgrid/mail": "^8.1.5",
    "@slack/web-api": "^7.9.3",
    "dotenv": "^16.5.0",
    "dotenv-expand": "^12.0.2",
    "firebase-admin": "^13.4.0",
    "hono": "^4.7.10",
    "http-status-codes": "^2.3.0",
    "jsonwebtoken": "^9.0.2",
    "lodash-es": "^4.17.21",
    "openai": "^5.10.2",
    "stripe": "^18.3.0",
    "uuid": "^11.1.0",
    "zod": "^3.25.64"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^20.11.17",
    "eslint": "^9.28.0",
    "globals": "^16.2.0",
    "prettier": "^3.5.3",
    "prisma": "^6.10.0",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.0"
  }
}
